{
  "workspaces": [
    "html-template"
  ],
  "name": "@elvishscout/mdstory",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElvishScout/mdstory.git"
  },
  "version": "0.2.2",
  "description": "An interactive fiction scripting format based on Markdown and Handlebars.",
  "main": "./dist/index.js",
  "sideEffects": false,
  "type": "module",
  "files": [
    "./dist",
    "./types",
    "./html-template/dist",
    "./skills",
    "./examples/compact",
    "./README*.md",
    "./WRITING_GUIDE*.md"
  ],
  "bin": {
    "mdstory": "dist/cli/index.js"
  },
  "scripts": {
    "prebuild": "shx rm -rf \"dist/*\" \"dist/.*\"",
    "postbuild": "shx chmod u+x \"dist/cli/index.js\"",
    "build": "tsc -b",
    "build:template": "cd html-template && npm run build",
    "build:all": "npm run build && npm run build:template",
    "cli": "node ./dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-attrs": "^4.1.3",
    "@types/node": "^22.20.0",
    "shx": "^0.4.0",
    "tsx": "^4.19.3",
    "typescript": "~5.7.2",
    "vitest": "^4.1.9",
    "words-count": "^2.0.2"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "handlebars": "^4.7.8",
    "inquirer": "^14.0.2",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-front-matter": "^0.2.4",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-terminal": "^0.4.0",
    "nanoid": "^5.1.16",
    "open": "^10.2.0",
    "zod": "^3.24.3"
  },
  "types": "./types",
  "keywords": [
    "markdown",
    "handlebars"
  ],
  "author": "Jiakai Jiang",
  "license": "ISC"
}
